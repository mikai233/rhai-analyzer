{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "cargo: build rhai-lsp",
      "command": "cargo",
      "args": [
        "build",
        "-p",
        "rhai-lsp"
      ],
      "options": {
        "cwd": "${workspaceFolder}/../.."
      },
      "group": "build",
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ],
      "label": "npm: build"
    },
    {
      "label": "build rhai-analyzer vscode dev",
      "dependsOrder": "sequence",
      "dependsOn": [
        "cargo: build rhai-lsp",
        "npm: build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
